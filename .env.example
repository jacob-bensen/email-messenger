# Sample environment variables. Documentation only — Spring Boot does NOT load
# this file automatically. Copy to .env and source it, or set these in your
# host/run config. Each var overrides application.yml via relaxed binding;
# anything omitted falls back to the default baked into application.yml.
#
# Local dev: run src/main/resources/db/init.sql, then start with the `local`
# profile. That profile hardcodes the JDBC URL/username, so locally only
# JDBC_DATABASE_PASSWORD is needed.

# === Required ===

# PostgreSQL — the app will not boot without these.
JDBC_DATABASE_URL=jdbc:postgresql://localhost:5432/email_messenger
JDBC_DATABASE_USERNAME=email_messenger_app
JDBC_DATABASE_PASSWORD=password

# Outgoing SMTP — needed to send replies, verification, and reset emails.
MAIL_HOST=smtp.postmarkapp.com
MAIL_PORT=587
MAIL_USER=your-api-token
MAIL_PASS=your-api-token

# Encrypts stored mailbox (IMAP/SMTP) passwords at rest. Set in prod, or
# stored credentials fall back to a public dev key.
MAILBOX_ENCRYPTION_PASSWORD=
MAILBOX_ENCRYPTION_SALT=

# === Optional (blank = feature off; everything else defaults sensibly) ===

# Google "Continue with Google" sign-in. Blank hides the button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe billing. Both required to enable checkout + webhook handling. Paid
# checkout also needs the plan price IDs and redirect URLs (billing.stripe.*
# in BillingProperties) — add them here when you take billing live.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
