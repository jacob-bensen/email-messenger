# Environment variables read by the prod profile (application.yml).
# Set these in your environment before running with --spring.profiles.active=prod

# PostgreSQL (required — the app will not boot without these)
DB_URL=jdbc:postgresql://localhost:5432/email_messenger
DB_USER=mailim
DB_PASS=change-me-strong-password

# Outgoing SMTP (Postmark, SendGrid, Resend, etc.)
MAIL_HOST=smtp.postmarkapp.com
MAIL_PORT=587
MAIL_USER=your-api-token
MAIL_PASS=your-api-token

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PERSONAL_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
STRIPE_PERSONAL_ANNUAL_PRICE_ID=
STRIPE_TEAM_ANNUAL_PRICE_ID=
STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=
BILLING_SUCCESS_URL=
BILLING_CANCEL_URL=
BILLING_PORTAL_RETURN_URL=

# Mailbox credential encryption at rest (required for connecting mailboxes)
MAILBOX_ENCRYPTION_PASSWORD=
MAILBOX_ENCRYPTION_SALT=

# Per-user mailbox IMAP polling
MAILBOX_POLLING_ENABLED=false

# Public canonical base URL — used for SEO endpoints and outbound links
MARKETING_BASE_URL=https://mailaim.app

# Google sign-in (optional; blank disables the button)
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# Scheduled email jobs (all off by default)
DIGEST_ENABLED=false
REENGAGEMENT_ENABLED=false
ACTIVATION_ENABLED=false
TRIAL_END_ENABLED=false
ADMIN_WEEKLY_DIGEST_ENABLED=false
ADMIN_EMAILS=

# App port (default 8080)
PORT=8080
