# Environment variables read by application.yml.
#
# Local dev: run src/main/resources/db/init.sql against your local
# PostgreSQL, then start the app with the `local` profile
# (--spring.profiles.active=local). The local profile hardcodes the JDBC
# URL and username, so only JDBC_DATABASE_PASSWORD is needed.

# PostgreSQL
JDBC_DATABASE_URL=jdbc:postgresql://localhost:5432/email_messenger
JDBC_DATABASE_USERNAME=email_messenger_app
JDBC_DATABASE_PASSWORD=password

# Outgoing SMTP (Postmark, SendGrid, Resend, etc.)
MAIL_HOST=smtp.postmarkapp.com
MAIL_PORT=587
MAIL_USER=your-api-token
MAIL_PASS=your-api-token

# IMAP polling (set IMAP_POLLING_ENABLED=true to activate)
IMAP_POLLING_ENABLED=false
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SSL=true
IMAP_FOLDER=INBOX
IMAP_USER=your-email@gmail.com
IMAP_PASS=your-app-password

# App port (default 8080)
PORT=8080

# Public canonical base URL — used for /sitemap.xml and /robots.txt
APP_BASE_URL=https://mailaim.app
